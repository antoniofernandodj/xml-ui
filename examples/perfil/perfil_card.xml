<Container
    padding="20"
    width="300"
    background="#1E1E2E"
    border_radius="16"
    border_width="1"
    border_color="#313244"
    alignX="Center"
>
    <Column spacing="15" align="Center">
        <Image
            source="examples/perfil/avatar.png"
            width="100"
            height="100"
            clip="Circle"
        />

        <Column spacing="5" align="Center">
            <Text
                content="{user_name}"
                size="20"
                bold="true" color="#CDD6F4"
            />
            <Text
                content="{user_role}"
                size="14"
                color="#A6ADC8"
            />
        </Column>

        <Button
            text="{texto_botao}"
            on_click="seguir_usuario"
            width="fill"
            color="{btn_color}"
            padding="10 15"
        />
    </Column>
</Container>
