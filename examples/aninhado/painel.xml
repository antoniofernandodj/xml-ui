<Container
    padding="30"
    width="fill"
    height="fill"
    background="{painel_bg}"
    alignX="Center"
    alignY="Center"
>
    <Column spacing="20" width="360" align="Center">
        <Text content="Painel (tema {tema})" size="26" bold="true" color="{cor_texto}" />

        <!-- Filho COM comportamento próprio. Os botões dentro de
             cartao_contador.xml são roteados para o update de CartaoContador,
             não para o do Painel. Sem <import>: o children() do Painel já
             registra o template e o comportamento do filho. -->
        <CartaoContador />

        <Button
            text="Trocar tema"
            on_click="trocar_tema"
            color="#89B4FA"
            width="fill"
            padding="12"
        />
    </Column>
</Container>
