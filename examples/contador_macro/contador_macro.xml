<style>
.center-xy {
    align-x: Center;
    align-y: Center;
}

.center {
    align: Center;
}

.fill {
    width: fill;
    height: fill;
}

.gray {
    color: #2E3440;
}

.p-20 {
    padding: 20;
}
</style>

<Container class="center-xy fill gray p-20">
    <Column spacing="20" class="center">
        <Text
            content="Valor do Contador: {contador}"
            size="28"
            bold="true"
            color="#ECEFF4"
        />
        <Row spacing="15" align="Center">
            <Button
                text="Diminuir"
                on_click="decrementar"
                color="#BF616A"
                padding="10 20"
            />
            <Button
                text="Aumentar"
                on_click="incrementar"
                color="#A3BE8C"
                padding="10 20"
            />
        </Row>
    </Column>
</Container>

<script>

-- Comportamento em Lua, interpretado em tempo de execução (sem compilar).
-- O contexto do motor é a tabela global `ctx`: ler/escrever `ctx.contador`
-- atualiza o binding {contador} da markup acima.

function init()
    ctx.contador = ctx.contador or 0
end

function incrementar()
    ctx.contador = ctx.contador + 1
end

function decrementar()
    ctx.contador = ctx.contador - 1
end

</script>
