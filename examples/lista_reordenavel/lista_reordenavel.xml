<!-- Lista de tarefas reordenável por drag-and-drop: arraste pelo "⋮⋮" (o
     `dragHandle`) de um item até a posição de outro para trocá-los de lugar.
     `onReorder` dispara quando o item é solto, carregando a nova ordem como um
     array JSON dos valores de `reorderKey` (aqui, o campo "id" de cada tarefa). -->
<Container padding="20" width="fill" height="fill" background="#2E3440">
    <Column spacing="16">
        <Text content="Tarefas ({total}) — arraste pelo ⋮⋮ para reordenar" size="20" bold="true" color="#ECEFF4" />
        <Column spacing="8" width="fill">
            <!-- Durante o arrasto, cada item recebe `{t.__dragging}` = "true" no
                 item que está sendo segurado (injetado pelo engine). Trocamos o
                 fundo/borda para destacar a linha agarrada — o resto da lista
                 reflui em volta. -->
            <ForEach items="tarefas" var="t" onReorder="reordenar" reorderKey="id">
                <Row if="{t.__dragging}" equals="true"
                     spacing="10" padding="10 14" background="#434C5E"
                     borderRadius="8" borderWidth="1" borderColor="#88C0D0" alignY="Center">
                    <Text content="⋮⋮" dragHandle="true" cursor="grabbing" color="#88C0D0" size="18" />
                    <Text content="{t.nome}" color="#ECEFF4" width="fill" />
                </Row>
                <Row else="true"
                     spacing="10" padding="10 14" background="#3B4252"
                     borderRadius="8" alignY="Center">
                    <Text content="⋮⋮" dragHandle="true" cursor="grab" color="#88C0D0" size="18" />
                    <Text content="{t.nome}" color="#ECEFF4" width="fill" />
                </Row>
            </ForEach>
        </Column>
        <Text content="Última ordem confirmada: {ultima_ordem}" size="13" color="#81A1C1" />
    </Column>
</Container>
