<Container
    padding="20"
    width="fill"
    background="#1E1E2E"
    border_radius="16"
    border_width="1"
    border_color="#313244"
    alignX="Center"
>
    <Column spacing="15" align="Center">
        <Text
            content="Contador: {valor}"
            size="22"
            bold="true"
            color="#CDD6F4"
        />
        <Row spacing="15" align="Center">
            <Button
                text="-"
                onClick="decrementar"
                color="#BF616A"
                padding="10 20"
            />
            <Button
                text="+"
                onClick="incrementar"
                color="#A3BE8C"
                padding="10 20"
            />
        </Row>
    </Column>
</Container>
