// Formulário de login: `Form` agrupa os `TextInput`s ligados aos
// `FormControl`s do componente (por `formControl`, veja formulario_login.rs).
// Enter em qualquer campo sempre dispara `onSubmit`; se houver um próximo
// campo, o foco também avança para ele — dá para preencher e submeter o
// formulário inteiro sem tocar no mouse.
Container padding=24 width=fill height=fill background="#2E3440" {
    Column spacing=16 width=360 {
        Text "Entrar" size=24 bold color="#ECEFF4"
        Form onSubmit="entrar" name="login" {
            Column spacing=6 {
                Text "Usuário" size=13 color="#D8DEE9"
                TextInput formControl="username" placeholder="ao menos 3 caracteres"
                Text "{erro_username}" size=12 color="#BF616A"
            }
            Column spacing=6 {
                Text "Senha" size=13 color="#D8DEE9"
                TextInput formControl="password" placeholder="ao menos 6 caracteres" secure=true
                Text "{erro_password}" size=12 color="#BF616A"
            }
            Button text="Entrar" onClick="entrar" color="#5E81AC" width=fill
        }
        Text "{status}" size=13 color="#A3BE8C"
    }
}
