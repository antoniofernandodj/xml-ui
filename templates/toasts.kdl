// Painel de gatilhos para o exemplo `toasts`. Os toasts em si não fazem
// parte deste template — são construídos em Rust (ver examples/toasts.rs)
// e sobrepostos pelo motor via GlacierUI::render_current.
Container padding=30 alignX="center" alignY="center" width=fill height=fill background="#2E3440" {
    Column spacing=16 alignX="center" {
        Text "Toasts (info / sucesso / aviso / erro)" size=22 bold color="#ECEFF4"
        Text "Clique num botão para empilhar o toast correspondente; cada um some sozinho depois de alguns segundos." size=13 color="#D8DEE9"

        Row spacing=10 {
            Button "Info" onClick="mostrar_info" color="#5E81AC" padding="8 16"
            Button "Sucesso" onClick="mostrar_sucesso" color="#A3BE8C" padding="8 16"
            Button "Aviso" onClick="mostrar_aviso" color="#D08770" padding="8 16"
            Button "Erro" onClick="mostrar_erro" color="#BF616A" padding="8 16"
        }
        Row spacing=10 alignX="center" {
            Button "Com título + duração longa" onClick="mostrar_com_titulo" color="#B48EAD" padding="8 16"
            Button "Empilhar vários" onClick="mostrar_varios" color="#88C0D0" padding="8 16"
        }

        Rule width=440

        Text "Toasts disparados: {total_disparados}" size=14 color="#A3BE8C"
    }
}
