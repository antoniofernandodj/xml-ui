theme "crates/remote-ui/styles/theme.json"
import "Login" from="crates/remote-ui/templates/login.kdl"
import "Shell" from="crates/remote-ui/templates/shell.kdl"

// Borderless window (decorations=false): a 6px frame of resize handles wraps
// the content. Each handle sets its hover cursor and starts an interactive
// resize on press (window:resize:<dir>), handled in main.rs against the cached
// window id. glacier has no overlay/z-stack, so the frame is laid out as
// top row / middle band / bottom row.
Column class="screen" width="fill" height="fill" {

  // ── Top edge + top corners (north / nw / ne) ───────────────────────────
  Row class="rz_top" {

    Column
      class="rz_corner"
      cursor="resize-nw"
      on_press="window:resize:nw"

    Column
      class="rz_h"
      cursor="resize-v"
      on_press="window:resize:n"

    Column
      class="rz_corner"
      cursor="resize-ne"
      on_press="window:resize:ne"
  }

  // ── Middle band: left edge | body | right edge (west / east) ────────────
  Row class="rz_mid" {
    Column class="rz_v" cursor="resize-h" on_press="window:resize:w"
    Column class="rz_body" {
      // ── Custom titlebar ───────────────────────────────────────────
      // titlebar_drag (width:fill) is the drag handle and pushes the
      // controls to the right edge. on_press/onClick window:* actions are
      // handled in main.rs against the cached window id.
      Row class="titlebar" {

        Row
          class="titlebar_drag"
          on_press="window:drag"
          on_double_click="window:maximize" {
            Text "●" class="titlebar_dot"
            Text "Rustploy Remote" class="titlebar_title"
          }

        Button "—"
          class="win_btn"
          onClick="window:minimize"

        Button "▢"
          class="win_btn"
          onClick="window:maximize"

        Button "✕"
          class="win_close"
          onClick="window:close"
  
      }

      if cond="{screen}" equals="login" {
        Login
      } else {
        Shell
      }
    }

    Column
      class="rz_v"
      cursor="resize-h"
      on_press="window:resize:e"
  }

  // ── Bottom edge + bottom corners (south / sw / se) ──────────────────────
  Row class="rz_bottom" {

    Column
      class="rz_corner"
      cursor="resize-sw"
      on_press="window:resize:sw"

    Column
      class="rz_h"
      cursor="resize-v"
      on_press="window:resize:s"

    Column
      class="rz_corner"
      cursor="resize-se"
      on_press="window:resize:se"

  }
}
