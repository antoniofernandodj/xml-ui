Container class="login_wrap" {
  Column class="login_card" {
    Row class="login_head" {

      Svg "crates/remote-ui/assets/icons/terminal.svg"
        color="#2F81F7"
        width=34
        height=34

      Column class="login_brand" {
        Text "Rustploy Remote" class="login_title"
        Text "Infrastructure management for professional teams"
          class="subtitle"
      }
    }

    Column class="field_group" {

      Row class="field_row" {
        Text "SERVER URL" class="field_label_fill"
        Text "ENDPOINT" class="field_label"
      }

      TextInput "rwp://cluster.tech"
        class="field_input"
        value="url"
        onChange="url_changed"

    }

    Column class="field_group" {

      Row class="field_row" {
        Text "ACCESS TOKEN" class="field_label_fill"
        Text "SECURE" class="field_label"
      }

      TextInput "token de acesso"
        class="field_input"
        value="token"
        onChange="token_changed"
  
    }

    Column class="login_checks" {

      Checkbox "Remember server"
        checked="remember_url"
        onToggle="toggle_remember_url"

      Checkbox "Remember token"
        checked="remember_token"
        onToggle="toggle_remember_token"

    }

    Button "Connect" class="connect_btn" onClick="connect"
    Text "⚠ {error}" if="{error}" notEquals="" class="err"

    Rule

    Row class="status_row" {
      Text "●" class="ok" size=10
      Text "{status_line}" class="muted"
    }
  }
}
